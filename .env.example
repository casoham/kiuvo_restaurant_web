# ── Aplicación ──────────────────────────────────────────────
APP_NAME=DO Eat
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ── Base de datos ───────────────────────────────────────────
# Desarrollo local (SQLite):
DATABASE_URL=sqlite:///./restaurant.db

# Producción (Supabase — pooler IPv4, modo Transaction, puerto 6543):
# Copia la URI en Settings → Database → Connection string (Transaction).
# Ejemplo (reemplaza REGION; proyectos nuevos suelen usar aws-1-*):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Seguridad / JWT ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── CORS (separar orígenes con coma) ────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# ── SMTP — recuperación de contraseña (vacío = modo consola) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/restaurant.log
